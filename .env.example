# Copy this file to `.env` (gitignored) and fill in real values.
# Both src/bot.py and src/vrc_online_checker.py load it via python-dotenv.

# --- Discord (bot.py) ---
DISCORD_BOT_TOKEN=your-discord-bot-token

# --- Database (bot.py) ---
# PostgreSQL in production; sqlite works for quick local runs:
#   sqlite:///local_test.db
DATABASE_URL=postgresql://user:password@host:5432/vrcverify

# --- RabbitMQ (both services) ---
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_QUEUE_NAME=verification_requests
RABBITMQ_RESULT_QUEUE=verification_results

# --- VRChat account (vrc_online_checker.py) ---
VRCHAT_USERNAME=your-vrchat-username
VRCHAT_PASSWORD=your-vrchat-password

# --- Gmail IMAP for VRChat 2FA codes (vrc_online_checker.py) ---
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# --- Optional ---
LOG_LEVEL=INFO
# VRCHAT_API_CONNECT_TIMEOUT_SECONDS=10
# VRCHAT_API_READ_TIMEOUT_SECONDS=20
# VRCHAT_RELOGIN_INTERVAL_SECONDS=600
# INSTRUCTIONS_TRIGGER_PATH=/tmp/update_instructions.trigger
